# Netlify: set these in Site settings → Environment variables (or Build env vars).
# Do not commit real values.

# Required for AI Chat (DeepSeek)
# Get a key at https://platform.deepseek.com → add it in Netlify → redeploy
DEEPSEEK_API_KEY=your_deepseek_api_key

# Required for the contact form at the bottom to work
# Create a form at https://formspree.io → get the form ID (e.g. xyzabcde) → set:
VITE_FORMSPREE_CONTACT_ID=your_formspree_form_id

# Optional: to email you when someone books via the AI, create a Formspree form
# and set this to your form endpoint (e.g. https://formspree.io/f/xxxxx)
# FORMSPREE_BOOKING_ENDPOINT=https://formspree.io/f/xxxxx

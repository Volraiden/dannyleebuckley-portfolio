# Netlify: set these in Site settings → Environment variables.
# Do not commit real values.

# Required for AI Chat (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional: to email you when someone books via the AI, create a Formspree form
# and set this to your form endpoint (e.g. https://formspree.io/f/xxxxx)
# FORMSPREE_BOOKING_ENDPOINT=https://formspree.io/f/xxxxx
